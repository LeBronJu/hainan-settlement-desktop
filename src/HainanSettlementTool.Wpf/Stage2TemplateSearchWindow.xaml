<Window x:Class="HainanSettlementTool.Wpf.Stage2TemplateSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="搜索全部分表模板"
        Width="860"
        Height="600"
        MinWidth="700"
        MinHeight="460"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="{StaticResource PageBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border BorderBrush="{StaticResource WindowBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="搜索全部分表模板"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="16,0,52,0"
                               VerticalAlignment="Center" />
                    <Button Width="40"
                            Height="32"
                            HorizontalAlignment="Right"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource TextBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Cancel_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,18,22,12">
                <TextBlock Text="输入主体、负责人或文件名中的关键词；多个关键词以空格分隔，必须全部匹配。"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Style="{StaticResource ModernTextBox}"
                             Height="36"
                             FontSize="14"
                             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ResultCountText}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="22,0,22,0"
                    Background="{StaticResource PanelSoftBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0"
                          Background="#EEF3F5"
                          Margin="1,1,1,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.1*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="2.2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="主体"
                                   Foreground="{StaticResource FieldTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="12,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="负责人"
                                   Foreground="{StaticResource FieldTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="12,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="文件名"
                                   Foreground="{StaticResource FieldTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="12,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ListBox x:Name="ResultsList"
                             Grid.Row="1"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="ResultsList_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="#E2E8EB" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="RowBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background" Value="#EEF6F7" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBorder" Property="Background" Value="#DFF1F2" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.1*" />
                                        <ColumnDefinition Width="1.4*" />
                                        <ColumnDefinition Width="2.2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SubjectText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="12,7"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding OwnerText}"
                                               Foreground="{StaticResource FieldTextBrush}"
                                               FontSize="12"
                                               Margin="12,7"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FileName}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               Margin="12,7"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="22,14,22,18">
                <TextBlock Text="Enter 选择 · 双击选择 · Esc 取消"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            Width="90"
                            Height="34"
                            Style="{StaticResource SecondaryButton}"
                            IsCancel="True"
                            Click="Cancel_Click" />
                    <Button Content="使用所选模板"
                            Width="140"
                            MinWidth="0"
                            Height="34"
                            Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            IsDefault="True"
                            IsEnabled="{Binding CanConfirm}"
                            Click="Confirm_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
