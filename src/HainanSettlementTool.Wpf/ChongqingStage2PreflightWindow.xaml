<Window x:Class="HainanSettlementTool.Wpf.ChongqingStage2PreflightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重庆阶段二生成确认"
        Width="780"
        Height="640"
        MinWidth="700"
        MinHeight="540"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="#DDE5E8" BorderThickness="1" Background="White" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#FFF4DB" VerticalAlignment="Top">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="25"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="发现需要确认的重庆阶段二变化"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,22,0,12"
                    Background="#F8FBFB"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <TextBlock Text="请确认重庆阶段二生成前的预检项目。新增汇总主体必须选择支付方，确认后会继续生成输出分表、退补表和汇总表副本。"
                           Foreground="#34404A"
                           TextWrapping="Wrap" />
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FBFCFD">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="IssueGroupsList" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E1E7EA"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding CountText}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       Margin="12,2,0,0" />
                                            <TextBlock Text="{Binding Category}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>

                                        <ItemsControl ItemsSource="{Binding Issues}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FBFB"
                                                            BorderBrush="#EDF2F3"
                                                            BorderThickness="1"
                                                            CornerRadius="5"
                                                            Padding="12"
                                                            Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding PrimaryText}"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding FileText}"
                                                                       Foreground="#34404A"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,7,0,0"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding HandlingText}"
                                                                       Foreground="#8A5A00"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,7,0,0"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding ContextText}"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       FontSize="12"
                                                                       Margin="0,7,0,0"
                                                                       TextWrapping="Wrap" />
                                                            <StackPanel Visibility="{Binding PaymentSelectionVisibility}"
                                                                        Margin="0,10,0,0">
                                                                <TextBlock Text="选择支付方（必选）"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <ComboBox ItemsSource="{Binding PaymentPartyOptions}"
                                                                          SelectedValuePath="Value"
                                                                          SelectedValue="{Binding SelectedPaymentParty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          TextSearch.TextPath="DisplayText"
                                                                          IsTextSearchEnabled="True"
                                                                          Style="{StaticResource ModernComboBox}"
                                                                          Margin="0,5,0,0">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding DisplayText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Margin="0,12,0,0"
                       Foreground="{StaticResource ErrorBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Width="104" MinWidth="0" Height="36" Margin="0,0,12,0" Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                <Button Width="160" MinWidth="0" Height="36" Content="确认并生成" Style="{StaticResource PrimaryButton}" Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
