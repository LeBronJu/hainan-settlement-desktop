<Window x:Class="HainanSettlementTool.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="清能电力-结算自动化工具"
        Width="1240"
        Height="900"
        MinWidth="1240"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource PageBrush}">
    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1" Background="{DynamicResource PageBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="18,0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="5" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="清能电力-结算自动化工具" Margin="12,0,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="主题" Foreground="{DynamicResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="ThemeCombo" Width="116" Style="{StaticResource ModernComboBox}" SelectionChanged="ThemeCombo_SelectionChanged" Margin="0,0,14,0" />
                        <Border x:Name="StatusPill" Background="{DynamicResource StatusReadyBrush}" CornerRadius="14" Padding="12,5" Margin="0,0,14,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatusText" Text="就绪" Margin="8,0,0,0" FontSize="12" Foreground="{DynamicResource TextBrush}" />
                            </StackPanel>
                        </Border>
                        <Button Width="34" Height="32" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextBrush}" Background="Transparent" BorderThickness="0" Click="Minimize_Click" />
                        <Button Width="34" Height="32" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextBrush}" Background="Transparent" BorderThickness="0" Click="Maximize_Click" />
                        <Button Width="34" Height="32" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextBrush}" Background="Transparent" BorderThickness="0" Click="Close_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="348" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="190" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18,16" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="4" Height="20" CornerRadius="2" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="本次结算" Style="{StaticResource SectionTitle}" Margin="10,0,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="结算省份" VerticalAlignment="Center" Foreground="{DynamicResource FieldTextBrush}" />
                                <ComboBox x:Name="ProvinceCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" SelectionChanged="ProvinceCombo_SelectionChanged" />
                                <TextBlock Grid.Column="2" Text="请选择本次结算所属省份" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,6,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="126" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="88" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SettlementMonthLabel" Text="结算月份" VerticalAlignment="Center" Foreground="{DynamicResource FieldTextBrush}" />
                                <ComboBox x:Name="MonthCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" />
                                <TextBlock Grid.Column="2" Text="结果输出文件夹" VerticalAlignment="Center" Margin="26,0,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBox x:Name="OutputDirBox" Grid.Column="3" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                <Button Grid.Column="4" Content="打开" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="BrowseOutputDir_Click" />
                            </Grid>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="&#xE946;" Style="{StaticResource IconText}" Foreground="{DynamicResource MutedBrush}" FontSize="13" />
                                <TextBlock x:Name="SharedSettingsCaption" Text="阶段一和阶段二生成的所有文件都会保存到这个文件夹中" Style="{StaticResource CaptionText}" Margin="7,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl x:Name="MainTabControl"
                                Grid.Row="1"
                                Style="{StaticResource ModernTabControl}"
                                ItemContainerStyle="{StaticResource ModernTabItem}"
                                SelectionChanged="MainTabControl_SelectionChanged">
                        <TabItem x:Name="MainSettlementTab" Header="代理费结算">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ProvinceEmptyPanel" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource TabSelectedBorderBrush}" MinHeight="280" Padding="28" Focusable="False">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                                    <Border Width="56" Height="56" CornerRadius="28" Background="{DynamicResource ComboItemSelectedBrush}" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="请先选择结算省份" Margin="0,18,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="选择后会显示该省份可执行的结算阶段、输入文件和输出结果。" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource FieldTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="StageOnePanel" Grid.Column="0" Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource StageOneBorderBrush}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="64" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource StageOneHeaderBrush}" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource StageOneHeaderBorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Margin="16,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="21" Height="21" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M6,3 H17 L20,6 V21 H6 Z" />
                                                    <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M9,8 H16 M9,12 H16 M9,16 H14" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="Stage1TitleText" Text="阶段一：写入电量到台账" Margin="10,0,0,0" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock x:Name="Stage1CaptionText" Text="整理电量并写入基础台账，输出检查报告" Style="{StaticResource CaptionText}" Margin="31,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="16,10,16,12">
                                    <TextBlock x:Name="BaseLedgerLabel" Text="基础台账（必填）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <Grid x:Name="BaseLedgerRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BaseLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseBaseLedger_Click" />
                                    </Grid>

                                    <TextBlock x:Name="PowerLabel" Text="电量处理表" Style="{StaticResource FieldLabel}" />
                                    <Grid x:Name="PowerInputRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PowerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowsePower_Click" />
                                    </Grid>

                                    <TextBlock x:Name="RawDetailLabel" Text="原始零售侧明细" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="RawDetailBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseRawDetail_Click" />
                                    </Grid>

                                    <TextBlock x:Name="ReferenceLedgerLabel" Text="参考台账（可选）" Style="{StaticResource FieldLabel}" />
                                    <Grid x:Name="ReferenceLedgerRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ReferenceLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseReferenceLedger_Click" />
                                    </Grid>

                                    <CheckBox x:Name="CopyReferenceExistingCheckBox" Content="用参考台账覆盖已有客户 B:AB 列资料（谨慎）" Margin="0,7,0,8" Foreground="{DynamicResource FieldTextBrush}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RunStage1Button" Style="{StaticResource PrimaryButton}" Click="RunStage1_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                                                <TextBlock x:Name="RunStage1ButtonText" Text="开始 执行阶段一" Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="CleanPowerButton" Grid.Column="1" Content="只清洗电量" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="CleanPower_Click" />
                                        <Button x:Name="ClearStage1Button" Grid.Column="2" Content="清空" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="ClearStage1_Click" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="StageTwoPanel" Grid.Column="1" Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource StageTwoBorderBrush}" Margin="8,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="64" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource StageTwoHeaderBrush}" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource CompletionInnerBorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Margin="16,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="21" Height="21" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M3,4 H21 V20 H3 Z" />
                                                    <Path Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M3,9 H21 M8,4 V20 M13,4 V20 M18,4 V20" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="Stage2TitleText" Text="阶段二：生成分表和汇总表" Margin="10,0,0,0" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock x:Name="Stage2CaptionText" Text="生成代理/居间分表和汇总表，输出结算结果" Style="{StaticResource CaptionText}" Margin="31,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="16,10,16,12">
                                    <TextBlock Text="人工整理后的台账（必填）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CompletedLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseCompletedLedger_Click" />
                                    </Grid>

                                    <TextBlock Text="上月代理分表文件夹" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ProxyTemplateDirBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseProxyTemplateDir_Click" />
                                    </Grid>

                                    <TextBlock Text="上月居间分表文件夹" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="IntermediaryTemplateDirBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseIntermediaryTemplateDir_Click" />
                                    </Grid>

                                    <TextBlock x:Name="RefundTemplateDirLabel" Text="退补分表文件夹" Style="{StaticResource FieldLabel}" Visibility="Collapsed" />
                                    <Grid x:Name="RefundTemplateDirRow" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="RefundTemplateDirBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseRefundTemplateDir_Click" />
                                    </Grid>

                                    <TextBlock Text="上月/修正版汇总表（必填）" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SummaryTemplateBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseSummaryTemplate_Click" />
                                    </Grid>

                                    <CheckBox x:Name="AllowMissingOwnerCheckBox" Content="允许负责人缺失继续生成" Margin="0,7,0,8" Foreground="{DynamicResource FieldTextBrush}" />
                                    <DockPanel>
                                        <Button x:Name="RunStage2Button" Style="{StaticResource PrimaryButton}" Click="RunStage2_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                                                <TextBlock x:Name="RunStage2ButtonText" Text="开始 执行阶段二" Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ClearStage2Button" DockPanel.Dock="Right" Content="清空" Style="{StaticResource SecondaryButton}" Click="ClearStage2_Click" />
                                    </DockPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="EmployeeRewardTab" Header="员工电量奖励" ToolTipService.ShowOnDisabled="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource RewardBorderBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="64" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource RewardHeaderBrush}" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource RewardHeaderBorderBrush}" BorderThickness="0,0,0,1">
                                        <StackPanel Margin="16,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="21" VerticalAlignment="Center" />
                                                <TextBlock Text="员工电量奖励" Margin="10,0,0,0" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="按负责人统计所选月份电量，生成奖励总表和个人确认表" Style="{StaticResource CaptionText}" Margin="31,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="16,10,16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="最新售电结算台账（必填）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="82" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="RewardLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                                <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseRewardLedger_Click" />
                                            </Grid>

                                            <Border Background="{DynamicResource InfoPanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="输入说明" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                                    <TextBlock Text="电量、负责人、项目开发人和代理/自营关系均从最新台账读取。" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                                    <TextBlock Text="输出格式由工具内置，不需要另选模板。" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="奖励期间" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="RewardStartMonthCombo" Style="{StaticResource ModernComboBox}" />
                                                <TextBlock Grid.Column="1" Text="至" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource FieldTextBrush}" />
                                                <ComboBox x:Name="RewardEndMonthCombo" Grid.Column="2" Style="{StaticResource ModernComboBox}" />
                                            </Grid>

                                            <Border Background="{DynamicResource InfoPanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,16,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="生成内容" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                                    <TextBlock Text="员工电量奖励总表" Margin="0,10,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                                    <TextBlock Text="每个负责人一份员工电量确认表" Margin="0,6,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                                    <TextBlock Text="员工电量奖励校验报告" Margin="0,6,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                                </StackPanel>
                                            </Border>

                                            <DockPanel>
                                                <Button x:Name="RunEmployeeRewardButton" Style="{StaticResource PrimaryButton}" Click="RunEmployeeReward_Click">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                                                        <TextBlock Text="生成员工电量奖励表" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="ClearEmployeeRewardButton" DockPanel.Dock="Right" Content="清空" Style="{StaticResource SecondaryButton}" Click="ClearEmployeeReward_Click" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <Border Grid.Row="2" CornerRadius="8" Background="{DynamicResource LogBrush}" Padding="14" Margin="0,14,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="运行日志" Foreground="White" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="清空" Foreground="{DynamicResource LogActionBrush}" Background="Transparent" BorderThickness="0" Click="ClearLog_Click" />
                                    <Button Content="保存日志" Margin="18,0,0,0" Foreground="{DynamicResource LogActionBrush}" Background="Transparent" BorderThickness="0" Click="SaveLog_Click" />
                                </StackPanel>
                            </DockPanel>
                            <TextBox x:Name="LogBox"
                                     Grid.Row="1"
                                     Background="{DynamicResource LogBrush}"
                                     Foreground="{DynamicResource LogTextBrush}"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="310" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ProgressTitle" Text="等待执行" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,8">
                                <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="ProgressDescriptionText" Text="尚未开始" Margin="16,8,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                            </StackPanel>
                            <ProgressBar x:Name="ProgressBar" Grid.Row="2" Minimum="0" Maximum="100" Height="10" Value="0" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource ProgressTrackBrush}" />
                            <Grid Grid.Row="3" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="Step1Text" Text="○  检查输入文件" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBlock x:Name="Step1Status" Grid.Column="1" Text="等待中" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step2Text" Grid.Row="1" Text="○  读取台账数据" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBlock x:Name="Step2Status" Grid.Row="1" Grid.Column="1" Text="等待中" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step3Text" Grid.Row="2" Text="○  生成结算文件" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBlock x:Name="Step3Status" Grid.Row="2" Grid.Column="1" Text="等待中" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step4Text" Grid.Row="3" Text="○  写入结果报告" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBlock x:Name="Step4Status" Grid.Row="3" Grid.Column="1" Text="等待中" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step5Text" Grid.Row="4" Text="○  保存结果文件" Foreground="{DynamicResource FieldTextBrush}" />
                                <TextBlock x:Name="Step5Status" Grid.Row="4" Grid.Column="1" Text="等待中" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border x:Name="CompletionCard" Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource CompletionBorderBrush}" Background="{DynamicResource CompletionBrush}" Margin="0,14,0,0" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="CompletionIconCircle" Width="44" Height="44" CornerRadius="22" Background="{DynamicResource SuccessBrush}">
                                    <TextBlock x:Name="CompletionIconText" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock x:Name="CompletionTitleText" Text="执行完成" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="CompletionDetailText" Text="所有文件已成功生成" Margin="0,6,0,0" Foreground="{DynamicResource FieldTextBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource CompletionInnerBrush}" BorderBrush="{DynamicResource CompletionInnerBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,18,0,14">
                                <StackPanel>
                                    <TextBlock x:Name="CompletionOutputLabel" Text="输出文件夹" FontWeight="SemiBold" Foreground="{DynamicResource FieldTextBrush}" />
                                    <TextBlock x:Name="CompletionOutputText" Text="-" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="{DynamicResource CompletionInnerBrush}" BorderBrush="{DynamicResource CompletionInnerBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                        <TextBlock DockPanel.Dock="Left" Text="本次输出" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock DockPanel.Dock="Right" Text="最近一次" Foreground="{DynamicResource MutedBrush}" />
                                    </DockPanel>

                                    <TextBlock x:Name="NoProvinceResultHint" Text="选择省份后显示输出项" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,9" />

                                    <Grid x:Name="Stage1ResultRow" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="Stage1ResultLabel" Text="阶段一报告" Foreground="{DynamicResource FieldTextBrush}" />
                                        <Border Grid.Column="1" Background="{DynamicResource ResultPillBrush}" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="Stage1ResultStatus" Text="等待" Foreground="{DynamicResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="Stage1ResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="{DynamicResource FieldTextBrush}" />
                                    </Grid>
                                    <Grid x:Name="ProxyResultRow" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="代理分表" Foreground="{DynamicResource FieldTextBrush}" />
                                        <Border Grid.Column="1" Background="{DynamicResource ResultPillBrush}" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="ProxyResultStatus" Text="等待" Foreground="{DynamicResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="ProxyResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="{DynamicResource FieldTextBrush}" />
                                    </Grid>
                                    <Grid x:Name="IntermediaryResultRow" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="居间分表" Foreground="{DynamicResource FieldTextBrush}" />
                                        <Border Grid.Column="1" Background="{DynamicResource ResultPillBrush}" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="IntermediaryResultStatus" Text="等待" Foreground="{DynamicResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="IntermediaryResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="{DynamicResource FieldTextBrush}" />
                                    </Grid>
                                    <Grid x:Name="SummaryResultRow" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="汇总表" Foreground="{DynamicResource FieldTextBrush}" />
                                        <Border Grid.Column="1" Background="{DynamicResource ResultPillBrush}" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="SummaryResultStatus" Text="等待" Foreground="{DynamicResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="SummaryResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="{DynamicResource FieldTextBrush}" />
                                    </Grid>
                                    <Grid x:Name="EmployeeRewardResultRow" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="员工奖励" Foreground="{DynamicResource FieldTextBrush}" />
                                        <Border Grid.Column="1" Background="{DynamicResource ResultPillBrush}" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="EmployeeRewardResultStatus" Text="等待" Foreground="{DynamicResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="EmployeeRewardResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="{DynamicResource FieldTextBrush}" />
                                    </Grid>
                                    <DockPanel x:Name="FinishedAtRow" LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="完成时间" Foreground="{DynamicResource MutedBrush}" />
                                        <TextBlock x:Name="FinishedAtText" DockPanel.Dock="Right" Text="-" Foreground="{DynamicResource FieldTextBrush}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Button Grid.Row="4" Content="打开文件夹" Style="{StaticResource SecondaryButton}" Click="OpenOutputDir_Click" />
                        </Grid>
                    </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
