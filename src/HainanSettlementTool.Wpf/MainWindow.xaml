<Window x:Class="HainanSettlementTool.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="海南售电结算自动化工具"
        Width="1240"
        Height="900"
        MinWidth="1240"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource PageBrush}">
    <Border BorderBrush="#AEBBC4" BorderThickness="1" Background="{StaticResource PageBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FAFCFD" BorderBrush="#DDE5E8" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="18,0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="5" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="海南售电结算自动化工具" Margin="12,0,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="StatusPill" Background="#EAF7F1" CornerRadius="14" Padding="12,5" Margin="0,0,14,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatusText" Text="就绪" Margin="8,0,0,0" FontSize="12" Foreground="{StaticResource TextBrush}" />
                            </StackPanel>
                        </Border>
                        <Button Width="34" Height="32" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Click="Minimize_Click" />
                        <Button Width="34" Height="32" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Click="Maximize_Click" />
                        <Button Width="34" Height="32" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Click="Close_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="348" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="225" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18,16" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="4" Height="20" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="本次结算" Style="{StaticResource SectionTitle}" Margin="10,0,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="126" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="88" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="结算月份" VerticalAlignment="Center" Foreground="#34404A" />
                                <ComboBox x:Name="MonthCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}" />
                                <TextBlock Grid.Column="2" Text="结果输出文件夹" VerticalAlignment="Center" Margin="34,0,0,0" Foreground="#34404A" />
                                <TextBox x:Name="OutputDirBox" Grid.Column="3" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                <Button Grid.Column="4" Content="打开" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="BrowseOutputDir_Click" />
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="&#xE946;" Style="{StaticResource IconText}" Foreground="{StaticResource MutedBrush}" FontSize="13" />
                                <TextBlock Text="阶段一和阶段二生成的所有文件都会保存到这个文件夹中" Style="{StaticResource CaptionText}" Margin="7,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}" BorderBrush="#BBDDE1" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="78" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F1FBFC" CornerRadius="8,8,0,0" BorderBrush="#D5ECEE" BorderThickness="0,0,0,1">
                                    <StackPanel Margin="20,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M6,3 H17 L20,6 V21 H6 Z" />
                                                    <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M9,8 H16 M9,12 H16 M9,16 H14" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="阶段一：写入电量到台账" Margin="12,0,0,0" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="整理电量并写入基础台账，输出检查报告" Style="{StaticResource CaptionText}" Margin="36,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="20,14,20,18">
                                    <TextBlock Text="基础台账（必填）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BaseLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseBaseLedger_Click" />
                                    </Grid>

                                    <TextBlock Text="电量处理表" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PowerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowsePower_Click" />
                                    </Grid>

                                    <TextBlock Text="原始零售侧明细" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="RawDetailBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseRawDetail_Click" />
                                    </Grid>

                                    <TextBlock Text="参考台账（可选）" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ReferenceLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseReferenceLedger_Click" />
                                    </Grid>

                                    <CheckBox x:Name="CopyReferenceExistingCheckBox" Content="用参考台账覆盖已有客户 B:AB 列资料（谨慎）" Margin="0,10,0,10" Foreground="#34404A" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RunStage1Button" Style="{StaticResource PrimaryButton}" Click="RunStage1_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                                                <TextBlock Text="开始 执行阶段一" Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="CleanPowerButton" Grid.Column="1" Content="只清洗电量" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="CleanPower_Click" />
                                        <Button x:Name="ClearStage1Button" Grid.Column="2" Content="清空" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="ClearStage1_Click" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" BorderBrush="#BFDCC9" Margin="8,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="78" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F2FBF5" CornerRadius="8,8,0,0" BorderBrush="#DDEFE2" BorderThickness="0,0,0,1">
                                    <StackPanel Margin="20,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="{StaticResource SuccessBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M3,4 H21 V20 H3 Z" />
                                                    <Path Stroke="{StaticResource SuccessBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M3,9 H21 M8,4 V20 M13,4 V20 M18,4 V20" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="阶段二：生成分表和汇总表" Margin="12,0,0,0" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="生成代理/居间分表和汇总表，输出结算结果" Style="{StaticResource CaptionText}" Margin="36,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="20,14,20,18">
                                    <TextBlock Text="人工整理后的台账（必填）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CompletedLedgerBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseCompletedLedger_Click" />
                                    </Grid>

                                    <TextBlock Text="上月代理分表文件夹" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ProxyTemplateDirBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseProxyTemplateDir_Click" />
                                    </Grid>

                                    <TextBlock Text="上月居间分表文件夹" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="IntermediaryTemplateDirBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseIntermediaryTemplateDir_Click" />
                                    </Grid>

                                    <TextBlock Text="上月/修正版汇总表（必填）" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SummaryTemplateBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseSummaryTemplate_Click" />
                                    </Grid>

                                    <CheckBox x:Name="AllowMissingOwnerCheckBox" Content="允许负责人缺失继续生成" Margin="0,10,0,10" Foreground="#34404A" />
                                    <DockPanel>
                                        <Button x:Name="RunStage2Button" Style="{StaticResource PrimaryButton}" Click="RunStage2_Click">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                                                <TextBlock Text="开始 执行阶段二" Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ClearStage2Button" DockPanel.Dock="Right" Content="清空" Style="{StaticResource SecondaryButton}" Click="ClearStage2_Click" />
                                    </DockPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" CornerRadius="8" Background="#17202A" Padding="14" Margin="0,14,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="运行日志" Foreground="White" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="清空" Foreground="#D7E4EA" Background="Transparent" BorderThickness="0" Click="ClearLog_Click" />
                                    <Button Content="保存日志" Margin="18,0,0,0" Foreground="#D7E4EA" Background="Transparent" BorderThickness="0" Click="SaveLog_Click" />
                                </StackPanel>
                            </DockPanel>
                            <TextBox x:Name="LogBox"
                                     Grid.Row="1"
                                     Background="#17202A"
                                     Foreground="#D8E7EC"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="310" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ProgressTitle" Text="等待执行" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,8">
                                <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="ProgressDescriptionText" Text="尚未开始" Margin="16,8,0,0" Foreground="#34404A" />
                            </StackPanel>
                            <ProgressBar x:Name="ProgressBar" Grid.Row="2" Minimum="0" Maximum="100" Height="10" Value="0" Foreground="{StaticResource AccentBrush}" Background="#E4EAED" />
                            <Grid Grid.Row="3" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="86" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="Step1Text" Text="○  检查输入文件" Foreground="#34404A" />
                                <TextBlock x:Name="Step1Status" Grid.Column="1" Text="等待中" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step2Text" Grid.Row="1" Text="○  读取台账数据" Foreground="#34404A" />
                                <TextBlock x:Name="Step2Status" Grid.Row="1" Grid.Column="1" Text="等待中" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step3Text" Grid.Row="2" Text="○  生成结算文件" Foreground="#34404A" />
                                <TextBlock x:Name="Step3Status" Grid.Row="2" Grid.Column="1" Text="等待中" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step4Text" Grid.Row="3" Text="○  写入结果报告" Foreground="#34404A" />
                                <TextBlock x:Name="Step4Status" Grid.Row="3" Grid.Column="1" Text="等待中" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                                <TextBlock x:Name="Step5Text" Grid.Row="4" Text="○  保存结果文件" Foreground="#34404A" />
                                <TextBlock x:Name="Step5Status" Grid.Row="4" Grid.Column="1" Text="等待中" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" x:Name="CompletionCard" Style="{StaticResource CardBorder}" BorderBrush="#A9D9BB" Background="#F7FCF8" Margin="0,14,0,0" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource SuccessBrush}">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock x:Name="CompletionTitleText" Text="执行完成" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock x:Name="CompletionDetailText" Text="所有文件已成功生成" Margin="0,6,0,0" Foreground="#34404A" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Background="White" BorderBrush="#DDEFE2" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,18,0,14">
                                <StackPanel>
                                    <TextBlock Text="输出文件夹" FontWeight="SemiBold" Foreground="#34404A" />
                                    <TextBlock x:Name="CompletionOutputText" Text="-" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Background="White" BorderBrush="#DDEFE2" BorderThickness="1" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                        <TextBlock DockPanel.Dock="Left" Text="本次输出" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock DockPanel.Dock="Right" Text="最近一次" Foreground="{StaticResource MutedBrush}" />
                                    </DockPanel>

                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="阶段一报告" Foreground="#34404A" />
                                        <Border Grid.Column="1" Background="#ECF8F0" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="Stage1ResultStatus" Text="等待" Foreground="{StaticResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="Stage1ResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="#34404A" />
                                    </Grid>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="代理分表" Foreground="#34404A" />
                                        <Border Grid.Column="1" Background="#ECF8F0" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="ProxyResultStatus" Text="等待" Foreground="{StaticResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="ProxyResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="#34404A" />
                                    </Grid>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="居间分表" Foreground="#34404A" />
                                        <Border Grid.Column="1" Background="#ECF8F0" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="IntermediaryResultStatus" Text="等待" Foreground="{StaticResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="IntermediaryResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="#34404A" />
                                    </Grid>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="汇总表" Foreground="#34404A" />
                                        <Border Grid.Column="1" Background="#ECF8F0" CornerRadius="11" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="SummaryResultStatus" Text="等待" Foreground="{StaticResource SuccessBrush}" FontSize="12" />
                                        </Border>
                                        <TextBlock x:Name="SummaryResultCount" Grid.Column="2" Text="-" HorizontalAlignment="Right" Foreground="#34404A" />
                                    </Grid>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="完成时间" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="FinishedAtText" DockPanel.Dock="Right" Text="-" Foreground="#34404A" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Button Grid.Row="4" Content="打开文件夹" Style="{StaticResource SecondaryButton}" Click="OpenOutputDir_Click" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
