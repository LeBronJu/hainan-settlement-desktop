<Window x:Class="HainanSettlementTool.Wpf.ConfirmRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认运行"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="#DDE5E8" BorderThickness="1" Background="White" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="确认运行" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />

            <Grid Grid.Row="1" Margin="0,22,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#FFF4DB" VerticalAlignment="Top">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="25"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" Text="即将执行" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    <TextBlock x:Name="MonthText" FontSize="13" Foreground="#34404A" Margin="0,0,0,8" />
                    <Border Background="#F8FBFB" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,2,0,0">
                        <StackPanel>
                            <TextBlock Text="输出文件夹" FontWeight="SemiBold" Foreground="#34404A" />
                            <TextBlock x:Name="OutputText" FontSize="13" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="确认后会开始写入或生成文件，请确保相关 Excel 文件已经关闭。" Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="104" MinWidth="0" Height="36" Margin="0,0,12,0" Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                <Button Width="128" MinWidth="0" Height="36" Content="开始执行" Style="{StaticResource PrimaryButton}" Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
