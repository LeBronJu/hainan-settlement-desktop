<Window x:Class="HainanSettlementTool.Wpf.Stage2PreflightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="阶段二预检确认"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="#DDE5E8" BorderThickness="1" Background="White" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#FFF4DB" VerticalAlignment="Top">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="25"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="发现需要确认的阶段二变化"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,22,0,12"
                    Background="#F8FBFB"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <TextBlock Text="这些变化不会自动判定为错误。确认无误后可以继续生成，程序会把预检内容和金额核对结果写入阶段二校验报告。"
                           Foreground="#34404A"
                           TextWrapping="Wrap" />
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FBFCFD">
                <TextBox x:Name="DetailBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0"
                         Background="#FBFCFD"
                         Foreground="{StaticResource TextBrush}"
                         FontSize="13"
                         Padding="14"
                         FontFamily="Microsoft YaHei UI" />
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Width="104" MinWidth="0" Height="36" Margin="0,0,12,0" Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                <Button Width="180" MinWidth="0" Height="36" Content="继续生成并写报告" Style="{StaticResource PrimaryButton}" Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
