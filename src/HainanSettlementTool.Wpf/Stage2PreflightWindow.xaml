<Window x:Class="HainanSettlementTool.Wpf.Stage2PreflightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:HainanSettlementTool.Core.Models;assembly=HainanSettlementTool.Core"
        Title="{Binding Title}"
        Width="920"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="#DDE5E8" BorderThickness="1" Background="White" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        CornerRadius="22"
                        VerticalAlignment="Top">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FFF4DB" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanConfirm}" Value="False">
                                    <Setter Property="Background" Value="#FFF0EF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="25"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanConfirm}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Heading}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding SummaryText}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="#FFF0EF"
                                BorderBrush="#F4B9B5"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="10,3"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding BlockerCountText}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#FFF7E5"
                                BorderBrush="#EACB82"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="10,3"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding RequiredDecisionCountText}"
                                       Foreground="#8A5A00"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#EAF3FA"
                                BorderBrush="#BED4E4"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="10,3">
                            <TextBlock Text="{Binding ReviewCountText}"
                                       Foreground="#315E78"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#F1F4F5"
                                BorderBrush="#D2DADD"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="10,3"
                                Margin="8,0,0,0">
                            <TextBlock Text="{Binding InformationCountText}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,20,0,12"
                    Background="#F8FBFB"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding IntroText}"
                               Foreground="#34404A"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BlockingMessage}"
                               Visibility="{Binding BlockingMessageVisibility}"
                               Foreground="{StaticResource ErrorBrush}"
                               FontWeight="SemiBold"
                               Margin="0,9,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FBFCFD">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding IssueGroups}" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="GroupBorder"
                                        Background="White"
                                        BorderBrush="#E1E7EA"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal"
                                                        Margin="16,0,0,0">
                                                <Border x:Name="GroupStatusBadge"
                                                        Background="#EAF0F2"
                                                        CornerRadius="10"
                                                        Padding="9,2">
                                                    <TextBlock x:Name="GroupStatusBadgeText"
                                                               Text="{Binding StatusText}"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Text="{Binding CountText}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="12"
                                                           Margin="8,3,0,0" />
                                            </StackPanel>
                                            <StackPanel MaxWidth="780"
                                                        HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Heading}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SupportingText}"
                                                           Visibility="{Binding SupportingTextVisibility}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="12"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DockPanel>

                                        <ItemsControl ItemsSource="{Binding Issues}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="IssueBorder"
                                                            Background="#F8FBFB"
                                                            BorderBrush="#E1E7EA"
                                                            BorderThickness="1"
                                                            CornerRadius="5"
                                                            Padding="12"
                                                            Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="True">
                                                                <Border x:Name="StatusBadge"
                                                                        DockPanel.Dock="Left"
                                                                        Background="#EAF0F2"
                                                                        CornerRadius="10"
                                                                        Padding="8,2"
                                                                        Margin="0,0,8,0"
                                                                        VerticalAlignment="Top">
                                                                    <TextBlock x:Name="StatusBadgeText"
                                                                               Text="{Binding StatusText}"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                                <StackPanel MaxWidth="760"
                                                                            HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Category}"
                                                                               Foreground="{StaticResource TextBrush}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding PrimaryText}"
                                                                               Foreground="#34404A"
                                                                               FontSize="13"
                                                                               Margin="0,3,0,0"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                            <TextBlock x:Name="HandlingTextBlock"
                                                                       Text="{Binding HandlingText}"
                                                                       Foreground="#315E78"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,7,0,0"
                                                                       MaxWidth="760"
                                                                       HorizontalAlignment="Left"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding ContextText}"
                                                                       Visibility="{Binding ContextTextVisibility}"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       FontSize="12"
                                                                       Margin="0,7,0,0"
                                                                       MaxWidth="760"
                                                                       HorizontalAlignment="Left"
                                                                       TextWrapping="Wrap" />
                                                            <StackPanel Visibility="{Binding PaymentSelectionVisibility}"
                                                                        Margin="0,12,0,0">
                                                                <TextBlock Text="选择支付方（必选，不会默认选择）"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <ComboBox ItemsSource="{Binding PaymentPartyOptions}"
                                                                          SelectedItem="{Binding SelectedPaymentParty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsTextSearchEnabled="True"
                                                                          Style="{StaticResource ModernComboBox}"
                                                                          Width="280"
                                                                          HorizontalAlignment="Left"
                                                                          Margin="0,5,0,0"
                                                                          SelectionChanged="Decision_SelectionChanged" />
                                                            </StackPanel>
                                                            <StackPanel Visibility="{Binding TemplateSelectionVisibility}"
                                                                        Margin="0,12,0,0">
                                                                <TextBlock Text="选择新分表的版式来源（必选，不会默认选择）"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <Border Background="#EAF7F7"
                                                                        BorderBrush="#9BCFD0"
                                                                        BorderThickness="1"
                                                                        CornerRadius="5"
                                                                        Padding="10"
                                                                        Margin="0,7,0,0"
                                                                        MaxWidth="760"
                                                                        HorizontalAlignment="Stretch"
                                                                        Visibility="{Binding TemplateBrowser.SelectedOptionVisibility}">
                                                                    <DockPanel LastChildFill="True">
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   Text="&#xE73E;"
                                                                                   FontFamily="Segoe MDL2 Assets"
                                                                                   Foreground="{StaticResource AccentDarkBrush}"
                                                                                   FontSize="15"
                                                                                   Margin="0,1,8,0" />
                                                                        <StackPanel>
                                                                            <TextBlock Text="已选择（切换批次后仍会保留）"
                                                                                       Foreground="{StaticResource AccentDarkBrush}"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold" />
                                                                            <TextBlock Text="{Binding TemplateBrowser.SelectedOption.SubjectText}"
                                                                                       Foreground="{StaticResource TextBrush}"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="0,2,0,0"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Foreground="{StaticResource MutedBrush}"
                                                                                       FontSize="11"
                                                                                       Margin="0,2,0,0"
                                                                                       TextWrapping="Wrap">
                                                                                <Run Text="{Binding TemplateBrowser.SelectedOption.OwnerText}" />
                                                                                <Run Text="  ·  " />
                                                                                <Run Text="{Binding TemplateBrowser.SelectedOption.FileName}" />
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                    </DockPanel>
                                                                </Border>
                                                                <DockPanel Margin="0,9,0,5"
                                                                           MaxWidth="760"
                                                                           LastChildFill="True">
                                                                    <Button DockPanel.Dock="Right"
                                                                            Content="搜索全部模板"
                                                                            Style="{StaticResource SecondaryButton}"
                                                                            Height="30"
                                                                            Margin="10,0,0,0"
                                                                            Click="SearchTemplates_Click" />
                                                                    <TextBlock Text="{Binding TemplateBrowser.BatchText}"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               FontSize="11"
                                                                               VerticalAlignment="Center" />
                                                                </DockPanel>
                                                                <ItemsControl ItemsSource="{Binding TemplateBrowser.VisibleOptions}"
                                                                              MaxWidth="760"
                                                                              HorizontalAlignment="Stretch">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="TemplateOption_Click"
                                                                                    Tag="{Binding Path}"
                                                                                    HorizontalContentAlignment="Stretch"
                                                                                    Padding="0"
                                                                                    Margin="0,0,0,5"
                                                                                    Cursor="Hand">
                                                                                <Button.Style>
                                                                                    <Style TargetType="Button">
                                                                                        <Setter Property="Background" Value="#FFFFFF" />
                                                                                        <Setter Property="BorderBrush" Value="#D9E2E6" />
                                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                                        <Setter Property="Template">
                                                                                            <Setter.Value>
                                                                                                <ControlTemplate TargetType="Button">
                                                                                                    <Border x:Name="CandidateBorder"
                                                                                                            Background="{TemplateBinding Background}"
                                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                                                            CornerRadius="5"
                                                                                                            Padding="10,8">
                                                                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                                                                          VerticalAlignment="Center" />
                                                                                                    </Border>
                                                                                                    <ControlTemplate.Triggers>
                                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                                            <Setter TargetName="CandidateBorder"
                                                                                                                    Property="Background"
                                                                                                                    Value="#F1F8F8" />
                                                                                                            <Setter TargetName="CandidateBorder"
                                                                                                                    Property="BorderBrush"
                                                                                                                    Value="#9BCFD0" />
                                                                                                        </Trigger>
                                                                                                    </ControlTemplate.Triggers>
                                                                                                </ControlTemplate>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                <Setter Property="Background" Value="#E3F4F4" />
                                                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                                                <Setter Property="BorderThickness" Value="2" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Button.Style>
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="22" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Text="&#xE73E;"
                                                                                               FontFamily="Segoe MDL2 Assets"
                                                                                               Foreground="{StaticResource AccentBrush}"
                                                                                               FontSize="13"
                                                                                               VerticalAlignment="Top"
                                                                                               Margin="0,2,0,0">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Hidden" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                    <StackPanel Grid.Column="1">
                                                                                        <TextBlock Text="{Binding SubjectText}"
                                                                                                   Foreground="{StaticResource TextBrush}"
                                                                                                   FontSize="13"
                                                                                                   FontWeight="SemiBold"
                                                                                                   TextWrapping="Wrap" />
                                                                                        <TextBlock Foreground="{StaticResource MutedBrush}"
                                                                                                   FontSize="11"
                                                                                                   Margin="0,2,0,0"
                                                                                                   TextWrapping="Wrap">
                                                                                            <Run Text="{Binding OwnerText}" />
                                                                                            <Run Text="  ·  " />
                                                                                            <Run Text="{Binding FileName}" />
                                                                                        </TextBlock>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,3,0,0"
                                                                            Visibility="{Binding TemplateBrowser.NavigationVisibility}">
                                                                    <Button Content="上一批"
                                                                            Style="{StaticResource SecondaryButton}"
                                                                            Height="30"
                                                                            IsEnabled="{Binding TemplateBrowser.CanMovePrevious}"
                                                                            Click="PreviousTemplateBatch_Click" />
                                                                    <Button Content="{Binding TemplateBrowser.NextButtonText}"
                                                                            Style="{StaticResource SecondaryButton}"
                                                                            Height="30"
                                                                            Margin="8,0,0,0"
                                                                            Click="NextTemplateBatch_Click" />
                                                                </StackPanel>
                                                                <TextBlock Text="只借用所选工作簿的分表版式；主体、客户、金额和税率仍按本月台账重新写入。"
                                                                           Foreground="{StaticResource MutedBrush}"
                                                                           FontSize="11"
                                                                           Margin="0,5,0,0"
                                                                           MaxWidth="760"
                                                                           HorizontalAlignment="Left"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Expander Visibility="{Binding TechnicalDetailsVisibility}"
                                                                      Header="查看文件与技术详情"
                                                                      IsExpanded="False"
                                                                      Foreground="{StaticResource MutedBrush}"
                                                                      Margin="0,10,0,0"
                                                                      MaxWidth="760"
                                                                      HorizontalAlignment="Left">
                                                                <Border Background="#F3F6F7"
                                                                        BorderBrush="#E1E7EA"
                                                                        BorderThickness="1"
                                                                        CornerRadius="4"
                                                                        Padding="10"
                                                                        Margin="0,5,0,0">
                                                                    <TextBlock Text="{Binding TechnicalDetailsText}"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap" />
                                                                </Border>
                                                            </Expander>
                                                        </StackPanel>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Disposition}"
                                                                     Value="{x:Static models:Stage2PreflightDisposition.Blocker}">
                                                            <Setter TargetName="IssueBorder" Property="Background" Value="#FFF4F3" />
                                                            <Setter TargetName="IssueBorder" Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                                                            <Setter TargetName="StatusBadge" Property="Background" Value="#FDE2E0" />
                                                            <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                            <Setter TargetName="HandlingTextBlock" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Disposition}"
                                                                     Value="{x:Static models:Stage2PreflightDisposition.RequiredDecision}">
                                                            <Setter TargetName="IssueBorder" Property="Background" Value="#FFF9ED" />
                                                            <Setter TargetName="IssueBorder" Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                                            <Setter TargetName="StatusBadge" Property="Background" Value="#FFF0CB" />
                                                            <Setter TargetName="StatusBadgeText" Property="Foreground" Value="#8A5A00" />
                                                            <Setter TargetName="HandlingTextBlock" Property="Foreground" Value="#8A5A00" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Disposition}"
                                                                     Value="{x:Static models:Stage2PreflightDisposition.Review}">
                                                            <Setter TargetName="IssueBorder" Property="Background" Value="#F7FAFF" />
                                                            <Setter TargetName="IssueBorder" Property="BorderBrush" Value="#BCD3E6" />
                                                            <Setter TargetName="StatusBadge" Property="Background" Value="#E6F1FA" />
                                                            <Setter TargetName="StatusBadgeText" Property="Foreground" Value="#315E78" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Disposition}"
                                                 Value="{x:Static models:Stage2PreflightDisposition.Blocker}">
                                        <Setter TargetName="GroupBorder" Property="BorderBrush" Value="#F4B9B5" />
                                        <Setter TargetName="GroupStatusBadge" Property="Background" Value="#FDE2E0" />
                                        <Setter TargetName="GroupStatusBadgeText" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Disposition}"
                                                 Value="{x:Static models:Stage2PreflightDisposition.RequiredDecision}">
                                        <Setter TargetName="GroupBorder" Property="BorderBrush" Value="#EACB82" />
                                        <Setter TargetName="GroupStatusBadge" Property="Background" Value="#FFF0CB" />
                                        <Setter TargetName="GroupStatusBadgeText" Property="Foreground" Value="#8A5A00" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Disposition}"
                                                 Value="{x:Static models:Stage2PreflightDisposition.Review}">
                                        <Setter TargetName="GroupBorder" Property="BorderBrush" Value="#BCD3E6" />
                                        <Setter TargetName="GroupStatusBadge" Property="Background" Value="#E6F1FA" />
                                        <Setter TargetName="GroupStatusBadgeText" Property="Foreground" Value="#315E78" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Margin="0,12,0,0"
                       Foreground="{StaticResource ErrorBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Width="104"
                        MinWidth="0"
                        Height="36"
                        Margin="0,0,12,0"
                        Content="取消"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button x:Name="ConfirmButton"
                        Width="190"
                        MinWidth="0"
                        Height="36"
                        Content="{Binding ConfirmButtonText}"
                        IsEnabled="{Binding CanConfirm}"
                        IsDefault="True"
                        ToolTip="请先处理阻断项并完成所有必选项"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource PrimaryButton}"
                        Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
