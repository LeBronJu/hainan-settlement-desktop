<Window x:Class="HainanSettlementTool.Wpf.ProvinceStage1LedgerPreflightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="生成本月台账前确认"
        Width="920"
        Height="720"
        MinWidth="800"
        MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource PanelBrush}"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        CornerRadius="22"
                        Background="{DynamicResource PanelSoftBrush}"
                        VerticalAlignment="Top">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="25"
                               Foreground="{DynamicResource WarningBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="HeadingText"
                               Text="预检报告"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,20,0,12">
                <ItemsControl x:Name="SummaryMetricsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource PanelSoftBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,8,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding Value}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Background="{DynamicResource PanelSoftBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <TextBlock x:Name="GuidanceText"
                               Text="请先查看需要检查的事项，再确认生成。"
                               Foreground="{DynamicResource FieldTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border x:Name="FocusPanel"
                            Background="{DynamicResource PanelSoftBrush}"
                            BorderBrush="{DynamicResource WarningBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Right"
                                           x:Name="FocusCountText"
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontSize="12"
                                           Margin="12,4,0,0" />
                                <TextBlock Text="重点检查"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="17"
                                           FontWeight="SemiBold" />
                            </DockPanel>
                            <ItemsControl x:Name="FocusGroupsList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelBrush}"
                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding CountText}"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               FontSize="12"
                                                               Margin="12,2,0,0" />
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding CustomerPreview}"
                                                           Foreground="{DynamicResource FieldTextBrush}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ActionText}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AutomaticPanel"
                            Background="{DynamicResource PanelSoftBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="程序已经处理"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="17"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="AutomaticItemsList" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat=✓  {0}}"
                                                   Foreground="{DynamicResource FieldTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ManualMatchPanel"
                            Background="{DynamicResource PanelSoftBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Right"
                                           x:Name="ManualMatchCountText"
                                           Foreground="{DynamicResource MutedBrush}"
                                           FontSize="12"
                                           Margin="12,4,0,0" />
                                <TextBlock Text="需要你选择客户"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="17"
                                           FontWeight="SemiBold" />
                            </DockPanel>

                            <Border x:Name="MatchingContextPanel"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="12"
                                    Margin="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="电量表客户不在台账"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="PowerOnlySummaryText"
                                                   Margin="0,5,0,0"
                                                   Foreground="{DynamicResource FieldTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                        <TextBlock Text="可选台账客户名称"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="LedgerOnlySummaryText"
                                                   Margin="0,5,0,0"
                                                   Foreground="{DynamicResource FieldTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsControl x:Name="ManualMatchList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelBrush}"
                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="待匹配客户名称"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding SourceCustomerName}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Margin="0,5,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE72A;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="选择处理方式或台账客户（必选）"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               FontSize="12" />
                                                    <ComboBox ItemsSource="{Binding TargetOptions}"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding SelectedTargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              TextSearch.TextPath="DisplayText"
                                                              IsTextSearchEnabled="True"
                                                              Style="{StaticResource ModernComboBox}"
                                                              Margin="0,5,0,0">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayText}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoManualMatchRowsText"
                                       Text="当前没有可执行的手动匹配；仅提示台账和电量表客户差异。"
                                       Foreground="{DynamicResource MutedBrush}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <Expander x:Name="TechnicalDetailsExpander"
                              IsExpanded="False"
                              Margin="0,0,0,4">
                        <Expander.Header>
                            <TextBlock x:Name="TechnicalDetailsHeaderText"
                                       Text="查看完整明细"
                                       Foreground="{DynamicResource FieldTextBrush}"
                                       FontWeight="SemiBold" />
                        </Expander.Header>
                        <Border Background="{DynamicResource PanelSoftBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,8,0,0">
                            <ItemsControl x:Name="IssueGroupsList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelBrush}"
                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding CountText}"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               FontSize="12"
                                                               Margin="12,2,0,0" />
                                                    <TextBlock Text="{Binding Category}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Issues}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{DynamicResource FieldTextBrush}"
                                                                       FontSize="13"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,6" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Margin="0,12,0,0"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Width="104"
                        MinWidth="0"
                        Height="36"
                        Margin="0,0,12,0"
                        Content="返回修改"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click" />
                <Button x:Name="ConfirmButton"
                        Width="200"
                        MinWidth="0"
                        Height="36"
                        Content="确认并生成本月台账"
                        Style="{StaticResource PrimaryButton}"
                        Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
