<Window x:Class="HainanSettlementTool.Wpf.ModernDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="{DynamicResource PageBrush}"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="False">
    <Border BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource PanelBrush}"
            MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="True"
                       Background="{DynamicResource TitleBarBrush}"
                       Margin="0"
                       MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                <Button DockPanel.Dock="Right"
                        Width="38"
                        Height="36"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Foreground="{DynamicResource TextBrush}"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="Close_Click" />
                <TextBlock x:Name="DialogTitleText"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="IconCircle"
                            Grid.Column="0"
                            Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource PanelSoftBrush}"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="IconText"
                                   Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="24"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="HeadingText"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="MessageText"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource FieldTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,24,0,0">
                    <Button x:Name="SecondaryButton"
                            Width="104"
                            MinWidth="0"
                            Height="36"
                            Margin="0,0,12,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="Secondary_Click" />
                    <Button x:Name="PrimaryButton"
                            Width="128"
                            MinWidth="0"
                            Height="36"
                            Style="{StaticResource PrimaryButton}"
                            Click="Primary_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
